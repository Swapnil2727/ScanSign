<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — 108×108dp canvas.
  Safe zone (visible in all launcher shapes): centre 72×72dp, offset 18dp from each edge.

  Design: white document page with folded top-right corner, four scan viewfinder
  corner marks, content lines, and a signature S-curve at the bottom.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Document body — white polygon with folded top-right corner.
      Page: left=26, top=14, right=82, bottom=94.
      Fold cut: from (66,14) diagonal down to (82,30).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,14 L66,14 L82,30 L82,92 Q82,94 80,94 L28,94 Q26,94 26,92 L26,16 Q26,14 28,14 Z" />

    <!--
      Folded corner triangle — light blue tint simulates the underside of the fold.
      Sits on top of the white document in the top-right area.
    -->
    <path
        android:fillColor="#BBDEFB"
        android:pathData="M66,14 L82,30 L66,30 Z" />

    <!--
      Scan viewfinder corner marks (L-shapes).
      They form a rectangle from (36,30) to (72,84) — the "scan frame" inside the document.
      Stroke colour matches the background blue so they stand out against white.
    -->

    <!-- Top-left L -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1565C0"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M46,30 L36,30 L36,40" />

    <!-- Top-right L -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1565C0"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M62,30 L72,30 L72,40" />

    <!-- Bottom-left L -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1565C0"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M36,74 L36,84 L46,84" />

    <!-- Bottom-right L -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1565C0"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M72,74 L72,84 L62,84" />

    <!--
      Document content lines — suggest text/content being scanned.
      Light blue so they read as "content" without competing with the viewfinder marks.
    -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#90CAF9"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M40,50 L68,50" />

    <path
        android:fillColor="#00000000"
        android:strokeColor="#90CAF9"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M40,59 L68,59" />

    <!--
      Signature S-curve — the "Sign" half of ScanSign.
      A smooth wave drawn in brand blue, replacing the third content line.
      Reads as a handwritten signature at a glance.
    -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1565C0"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M40,70 Q48,64 54,70 Q60,76 68,70" />

</vector>
